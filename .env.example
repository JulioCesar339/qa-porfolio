# Base de datos PostgreSQL
# Cambia estos valores según tu configuración local
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=your_database_name

# Cadena de conexión para la API
# Formato: Host=<host>;Port=<port>;Database=<db>;Username=<user>;Password=<pass>
DB_CONNECTION=Host=db;Port=5432;Database=your_database_name;Username=your_postgres_user;Password=your_postgres_password

# Entorno de la aplicación (Development, Production)
ASPNETCORE_ENVIRONMENT=Development